<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
:root {
  --bg: #fbfbf3; --bg-card: #f4f4eb; --ink: #111110;
  --muted: #888880; --border: #e4e4da;
  --green: #1a7a4a; --green-bg: #edf7f2; --gold: #c9a84c;
  --orange: #e85d04;
}
html { scroll-behavior: smooth; }
body { background: var(--bg); color: var(--ink); font-family: 'Manrope', sans-serif; font-weight: 400; line-height: 1.6; min-height: 100vh; }

/* ══ NAV ══ */
nav {
  position: sticky; top: 0; z-index: 50;
  background: rgba(251,251,243,0.95); backdrop-filter: blur(14px);
  border-bottom: 1px solid var(--border);
  padding: 0 2rem; height: 58px;
  display: flex; align-items: center; justify-content: space-between; gap: 1rem;
}
.logo { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.1rem; letter-spacing: -0.02em; color: var(--ink); text-decoration: none; }
.logo span { color: var(--muted); font-weight: 400; }
.nav-pill {
  display: flex; align-items: center; gap: 0.45rem;
  background: var(--green-bg); color: var(--green);
  font-size: 0.72rem; font-weight: 600; padding: 0.38rem 0.85rem;
  border-radius: 100px; border: 1px solid rgba(26,122,74,0.2);
}
.nav-pill::before { content:''; width:6px; height:6px; border-radius:50%; background:var(--green); animation:blink 2s ease infinite; }
@keyframes blink { 0%,100%{opacity:1;}50%{opacity:0.3;} }

/* ══ NAV RIGHT GROUP ══ */
.nav-right { display: flex; align-items: center; gap: 0.75rem; }

/* ══ LANGUAGE DROPDOWN ══ */
.lang-dropdown-wrap { position: relative; }
.lang-btn {
  display: inline-flex; align-items: center; gap: 0.4rem;
  font-family: 'Manrope', sans-serif; font-size: 0.72rem; font-weight: 600;
  padding: 0.38rem 0.75rem; border-radius: 8px;
  border: 1.5px solid var(--border);
  background: var(--bg); color: var(--ink);
  cursor: pointer; transition: border-color 0.15s, background 0.15s;
  white-space: nowrap;
}
.lang-btn:hover { border-color: var(--ink); background: var(--bg-card); }
.lang-btn .lp-flag { font-size: 0.9rem; }
.lang-btn-chev { width: 12px; height: 12px; stroke: currentColor; fill: none; stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round; transition: transform 0.2s; }
.lang-dropdown-wrap.open .lang-btn-chev { transform: rotate(180deg); }
.lang-dropdown {
  position: absolute; top: calc(100% + 6px); right: 0;
  background: var(--bg); border: 1.5px solid var(--border);
  border-radius: 10px; padding: 0.35rem;
  box-shadow: 0 8px 24px rgba(0,0,0,0.1);
  display: none; z-index: 200;
  min-width: 130px;
  animation: dropIn 0.15s ease;
}
@keyframes dropIn { from{opacity:0;transform:translateY(-6px);}to{opacity:1;transform:translateY(0);} }
.lang-dropdown-wrap.open .lang-dropdown { display: block; }
.lang-opt {
  display: flex; align-items: center; gap: 0.5rem;
  padding: 0.38rem 0.65rem; border-radius: 6px;
  font-size: 0.75rem; font-weight: 600; color: var(--ink);
  cursor: pointer; border: none; background: none; width: 100%; text-align: left;
  transition: background 0.1s;
}
.lang-opt:hover { background: var(--bg-card); }
.lang-opt.active { background: var(--ink); color: var(--bg); }
.lang-opt .lp-flag { font-size: 0.95rem; }

/* ══ QUOTE BANNER ══ */
.quote-banner { background: #1a1a18; }
.quote-inner {
  max-width: 680px; margin: 0 auto; padding: 0.8rem 2rem;
  display: flex; align-items: center; gap: 0.75rem;
}
.quote-icon { font-size: 0.9rem; opacity: 0.5; flex-shrink: 0; }
.quote-text { font-size: 0.76rem; color: rgba(251,251,243,0.65); font-style: italic; line-height: 1.5; flex:1; transition: opacity 0.3s; }
.quote-text strong { color: rgba(251,251,243,0.92); font-style: normal; }
.quote-next { background: none; border: none; color: rgba(251,251,243,0.3); font-size: 1rem; cursor: pointer; padding: 0.2rem 0.35rem; transition: color 0.15s; flex-shrink: 0; }
.quote-next:hover { color: rgba(251,251,243,0.8); }

/* ══ HERO ══ */
.hero { max-width: 680px; margin: 0 auto; padding: 4.5rem 2rem 3rem; text-align: center; }
.hero-badge { display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); border: 1px solid var(--border); padding: 0.38rem 1rem; border-radius: 100px; margin-bottom: 1.75rem; opacity:0; animation: fadeUp 0.5s ease 0.1s forwards; }
.hero h1 { font-family: 'Syne', sans-serif; font-weight: 800; font-size: clamp(2rem, 6vw, 3.6rem); line-height: 1.07; letter-spacing: -0.035em; margin-bottom: 1.1rem; opacity:0; animation: fadeUp 0.5s ease 0.2s forwards; }
.hero h1 u { text-decoration: none; border-bottom: 3px solid var(--ink); padding-bottom: 1px; }
.hero p { font-size: 0.98rem; color: var(--muted); max-width: 420px; margin: 0 auto 2.25rem; opacity:0; animation: fadeUp 0.5s ease 0.3s forwards; }
.hero-actions { display: flex; gap: 0.7rem; justify-content: center; flex-wrap: wrap; opacity:0; animation: fadeUp 0.5s ease 0.4s forwards; }

/* ══ TRUST BAR ══ */
.trust-bar { max-width: 680px; margin: 0 auto; padding: 0 2rem 2.25rem; display: flex; align-items: center; justify-content: center; gap: 1.5rem; flex-wrap: wrap; opacity:0; animation: fadeUp 0.5s ease 0.55s forwards; }
.trust-item { display: flex; align-items: center; gap: 0.4rem; font-size: 0.76rem; color: var(--muted); font-weight: 500; }
.trust-item svg { width: 12px; height: 12px; flex-shrink: 0; stroke: var(--green); fill: none; stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round; }
.trust-sep { width: 1px; height: 12px; background: var(--border); }

/* ══ BUTTONS ══ */
.btn { display: inline-flex; align-items: center; gap: 0.45rem; font-family: 'Manrope', sans-serif; font-size: 0.875rem; font-weight: 600; padding: 0.72rem 1.45rem; border-radius: 8px; text-decoration: none; border: none; cursor: pointer; transition: transform 0.15s, box-shadow 0.15s, background 0.15s; }
.btn:active { transform: scale(0.97) !important; }
.btn-dark { background: var(--ink); color: var(--bg); box-shadow: 0 2px 8px rgba(0,0,0,0.15); }
.btn-dark:hover { background: #2a2a28; transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,0.2); }
.btn-wa { background: #25d366; color: #fff; box-shadow: 0 2px 8px rgba(37,211,102,0.3); }
.btn-wa:hover { background: #1fbd5a; transform: translateY(-2px); box-shadow: 0 6px 20px rgba(37,211,102,0.4); }
.btn-outline { background: transparent; color: var(--ink); border: 1.5px solid var(--border); }
.btn-outline:hover { border-color: var(--ink); background: var(--bg-card); transform: translateY(-2px); }
.ico { width: 16px; height: 16px; flex-shrink: 0; }
.ico-wa { fill: white; }
.ico-mail { stroke: currentColor; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }

/* ══ SECTION ══ */
.section { max-width: 680px; margin: 0 auto; padding: 2.75rem 2rem; border-top: 1px solid var(--border); }
.section-label { font-size: 0.67rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); margin-bottom: 1.1rem; }

/* ══ CONTACT CARDS ══ */
.contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.875rem; }
.contact-card { background: var(--bg-card); border: 1.5px solid var(--border); border-radius: 12px; padding: 1.3rem; color: var(--ink); display: flex; flex-direction: column; gap: 0.65rem; transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s; }
.contact-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
.card-wa { background: #f0fdf6; border-color: rgba(37,211,102,0.3); }
.card-wa:hover { border-color: #25d366; box-shadow: 0 8px 24px rgba(37,211,102,0.12); }
.card-icon { width: 32px; height: 32px; border-radius: 7px; background: var(--border); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.card-wa .card-icon { background: #25d366; }
.card-icon svg { width: 16px; height: 16px; }
.card-type { font-size: 0.65rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); }
.card-value { font-family: 'Syne', sans-serif; font-size: 0.88rem; font-weight: 700; }
.card-actions { display: flex; gap: 0.45rem; }
.card-btn { flex:1; display: inline-flex; align-items: center; justify-content: center; gap: 0.3rem; font-family: 'Manrope', sans-serif; font-size: 0.7rem; font-weight: 600; padding: 0.45rem 0.5rem; border-radius: 6px; cursor: pointer; text-decoration: none; border: 1.5px solid var(--border); background: var(--bg); color: var(--ink); transition: background 0.15s, border-color 0.15s, transform 0.1s; white-space: nowrap; }
.card-btn:hover { background: var(--bg-card); border-color: #bbb; transform: translateY(-1px); }
.card-btn.copied { background: #edf7f2; border-color: rgba(26,122,74,0.3); color: var(--green); }
.card-btn svg { width: 12px; height: 12px; flex-shrink: 0; }

/* ══ REVIEWS ══ */
.reviews-section { max-width: 680px; margin: 0 auto; padding: 2.75rem 2rem; border-top: 1px solid var(--border); }
.reviews-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.25rem; flex-wrap: wrap; gap: 0.75rem; }
.rating-summary { display: flex; align-items: center; gap: 0.75rem; }
.rating-big { font-family: 'Syne', sans-serif; font-size: 2rem; font-weight: 800; line-height: 1; letter-spacing: -0.04em; }
.rating-detail { display: flex; flex-direction: column; gap: 0.2rem; }
.stars { display: flex; gap: 2px; }
.star { color: var(--gold); font-size: 0.82rem; }
.rating-count { font-size: 0.7rem; color: var(--muted); font-weight: 500; }
.reviews-nav { display: flex; gap: 0.4rem; }
.rev-btn { width: 30px; height: 30px; border-radius: 7px; border: 1.5px solid var(--border); background: var(--bg); cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 0.82rem; color: var(--ink); transition: border-color 0.15s, background 0.15s; }
.rev-btn:hover { border-color: var(--ink); background: var(--bg-card); }
.reviews-slider { overflow: hidden; }
.reviews-track { display: flex; gap: 0.875rem; transition: transform 0.4s cubic-bezier(0.4,0,0.2,1); }
.review-card { background: var(--bg-card); border: 1.5px solid var(--border); border-radius: 12px; padding: 1.2rem; flex-shrink: 0; display: flex; flex-direction: column; gap: 0.55rem; position: relative; }
.review-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 0.5rem; }
.reviewer { display: flex; align-items: center; gap: 0.55rem; min-width: 0; flex:1; }
.avatar { width: 32px; height: 32px; border-radius: 50%; font-family: 'Syne', sans-serif; font-weight: 700; font-size: 0.72rem; display: flex; align-items: center; justify-content: center; color: #fff; flex-shrink: 0; }
.reviewer-info { display: flex; flex-direction: column; gap: 0.1rem; min-width: 0; overflow: hidden; }
.reviewer-name { font-size: 0.78rem; font-weight: 700; font-family: 'Syne', sans-serif; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.reviewer-role { font-size: 0.63rem; color: var(--muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.review-stars span { color: var(--gold); font-size: 0.68rem; }
.review-text { font-size: 0.78rem; color: #555; line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
.review-date { font-size: 0.62rem; color: var(--muted); margin-top: auto; }
.reviews-dots { display: flex; justify-content: center; gap: 0.4rem; margin-top: 1.1rem; }
.dot { width: 6px; height: 6px; border-radius: 50%; background: var(--border); transition: background 0.2s, transform 0.2s; cursor: pointer; }
.dot.active { background: var(--ink); transform: scale(1.3); }

/* ══ REVIEW SPENT BADGE ══ */
.review-spent {
  display: inline-flex; align-items: center; gap: 0.3rem;
  font-size: 0.6rem; font-weight: 700; letter-spacing: 0.06em;
  background: var(--green-bg); color: var(--green);
  border: 1px solid rgba(26,122,74,0.2);
  padding: 0.18rem 0.5rem; border-radius: 100px;
  margin-top: 0.1rem;
}
.review-spent::before { content:''; width:5px;height:5px;border-radius:50%;background:var(--green);flex-shrink:0; }

/* ══ FEATURED REVIEWS LABEL ══ */
.reviews-featured-label {
  display: inline-flex; align-items: center; gap: 0.4rem;
  font-size: 0.62rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
  color: var(--gold);
  background: rgba(201,168,76,0.1); border: 1px solid rgba(201,168,76,0.3);
  padding: 0.22rem 0.65rem; border-radius: 100px;
  margin-bottom: 1rem;
}

/* ══ PRICING CARD — clean glow ══ */
.pricing-fire {
  position: relative;
  background: var(--ink);
  border-radius: 16px;
  padding: 2.25rem 2rem;
  overflow: hidden;
  text-align: center;
}
/* subtle static warm glow at bottom */
.pricing-fire::before {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 70% 45% at 50% 110%, rgba(232,93,4,0.28) 0%, transparent 65%);
  pointer-events: none;
}
/* thin accent line at bottom */
.pricing-fire::after {
  content: '';
  position: absolute; bottom: 0; left: 15%; right: 15%; height: 2px;
  background: linear-gradient(90deg, transparent, #e85d04, #f48c06, #e85d04, transparent);
  pointer-events: none;
}
.fire-badge {
  display: inline-flex; align-items: center; gap: 0.35rem;
  background: rgba(232,93,4,0.2); color: #f48c06;
  border: 1px solid rgba(232,93,4,0.35);
  font-size: 0.65rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
  padding: 0.25rem 0.7rem; border-radius: 100px; margin-bottom: 1rem;
}
.fire-price-row { display: flex; align-items: baseline; justify-content: center; gap: 0.4rem; margin-bottom: 0.3rem; }
.fire-from { font-size: 0.78rem; color: rgba(251,251,243,0.45); font-weight: 500; margin-bottom: 0.85rem; }
.fire-amount {
  font-family: 'Syne', sans-serif; font-weight: 800;
  font-size: 3.5rem; line-height: 1; letter-spacing: -0.04em;
  color: #fff;
  text-shadow: 0 0 24px rgba(232,93,4,0.5), 0 0 48px rgba(232,93,4,0.2);
}
.fire-currency { font-family: 'Syne', sans-serif; font-size: 1.5rem; font-weight: 700; color: rgba(251,251,243,0.65); align-self: flex-start; margin-top: 0.7rem; }
.fire-desc { font-size: 0.85rem; color: rgba(251,251,243,0.55); margin-bottom: 0.5rem; line-height: 1.5; }
.fire-note { font-size: 0.72rem; color: rgba(251,251,243,0.32); margin-bottom: 1.5rem; font-style: italic; }
.fire-cta { margin-top: 0.25rem; }
.fire-cta .btn { font-size: 0.85rem; }

/* ══ PORTFOLIO ══ */
.portfolio-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
.port-card {
  background: var(--bg-card); border: 1.5px solid var(--border);
  border-radius: 12px; overflow: hidden; cursor: pointer;
  transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
}
.port-card:hover { transform: translateY(-3px); box-shadow: 0 10px 30px rgba(0,0,0,0.1); border-color: #ccc; }

/* browser chrome */
.port-preview { position: relative; background: #f0f0e8; padding: 0.5rem; }
.pp-browser { border-radius: 7px; overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,0.15); }
.pp-bar {
  background: #e8e8e0; height: 22px; display: flex; align-items: center; gap: 4px;
  padding: 0 8px; flex-shrink: 0;
}
.pp-bar span { width: 7px; height: 7px; border-radius: 50%; }
.pp-bar span:nth-child(1){ background:#ff5f56; }
.pp-bar span:nth-child(2){ background:#ffbd2e; }
.pp-bar span:nth-child(3){ background:#27c93f; }
.pp-url { flex: 1; text-align: center; font-size: 0.52rem; color: #888; font-family: monospace; }
.pp-body { height: 130px; overflow: hidden; position: relative; }

/* shine overlay */
.pp-shine {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.08) 0%, transparent 50%);
  pointer-events: none; border-radius: 7px;
}

/* ── SAAS body ── */
.pp-body--saas { background: #0f1117; padding: 0; }
.pp-nav-s { display: flex; align-items: center; justify-content: space-between; padding: 6px 10px; background: rgba(255,255,255,0.04); }
.pp-logo-s { width: 32px; height: 7px; background: #4f7df3; border-radius: 3px; }
.pp-links-s { display: flex; gap: 6px; }
.pp-links-s div { width: 20px; height: 5px; background: rgba(255,255,255,0.15); border-radius: 2px; }
.pp-hero-s { padding: 10px 10px 8px; }
.pp-headline-s { width: 70%; height: 9px; background: linear-gradient(90deg,#4f7df3,#7b5ea7); border-radius: 4px; margin-bottom: 5px; }
.pp-sub-s { width: 50%; height: 5px; background: rgba(255,255,255,0.12); border-radius: 3px; margin-bottom: 8px; }
.pp-btn-s { width: 48px; height: 12px; background: #4f7df3; border-radius: 5px; }
.pp-cards-s { display: flex; gap: 6px; padding: 0 10px; }
.pp-card-s { flex: 1; background: rgba(255,255,255,0.06); border-radius: 5px; padding: 5px; border: 1px solid rgba(255,255,255,0.08); }
.pp-card-num { height: 7px; background: rgba(255,255,255,0.3); border-radius: 2px; margin-bottom: 4px; width: 60%; }
.pp-card-bar { height: 5px; border-radius: 2px; width: 80%; }
.pp-card-s--1 .pp-card-bar { background: #4f7df3; }
.pp-card-s--2 .pp-card-bar { background: #2a9d63; }
.pp-card-s--3 .pp-card-bar { background: #e67e22; }

/* ── SHOP body ── */
.pp-body--shop 
